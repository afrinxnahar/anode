{
  "name": "@anode/supabase",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "supabase:dev": "pnpx supabase start",
    "supabase:init": "pnpx supabase init",
    "supabase:link": "pnpx supabase link --project-ref <your-project-ID>",
    "supabase:pull": "pnpx supabase db pull",
    "supabase:push": "pnpx supabase db push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "supabase": "catalog:",
    "typescript": "catalog:"
  }
}